# Приложение
ALLOWED_ORIGINS=*
URL_PREFIX=SVAh2O

# Защита приложения
ALGORITHM=HS256
REFRESH_TOKEN_EXPIRE_MINUTES=21600
SECRET_REFRESH_KEY=secret
ACCESS_TOKEN_EXPIRE_MINUTES=10
SECRET_ACCESS_KEY=secret
CSRF_TOKEN_EXPIRE_MINUTES=10
SECRET_CSRF_KEY=secret

# Админка
ADMIN_LOGIN=admin
ADMIN_PASSWORD=password

# Логи
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=web_app

